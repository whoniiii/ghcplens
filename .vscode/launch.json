{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ]
    },
    {
      "name": "Run Server (standalone)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/server.js"
    }
  ]
}
