{
  "name": "github-copilot-lens",
  "displayName": "Github-Copilot-Lens",
  "version": "1.3.0",
  "description": "GitHub Copilot Lens — Session Monitor Dashboard",
  "publisher": "JeonghoonLee",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghcpLens.open",
        "title": "Open Dashboard",
        "category": "GitHub Copilot Lens",
        "icon": {
          "light": "resources/icon-activitybar.svg",
          "dark": "resources/icon-activitybar.svg"
        }
      },
      {
        "command": "ghcpLens.resetConnect",
        "title": "Show Connect Screen",
        "category": "GitHub Copilot Lens"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-lens",
          "title": "GitHub Copilot Lens",
          "icon": "resources/icon-activitybar.svg"
        }
      ]
    },
    "views": {
      "copilot-lens": [
        {
          "id": "copilot-lens.welcome",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "GitHub Copilot Lens",
      "properties": {
        "ghcpLens.sessionStatePath": {
          "type": "string",
          "default": "",
          "description": "Path to .copilot/session-state directory. Leave empty for default (~/.copilot/session-state)"
        }
      }
    }
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "vitest run --reporter=verbose",
    "prevsce": "powershell -Command \"Copy-Item README.md README.github.md; Copy-Item README.vsix.md README.md\"",
    "postvsce": "powershell -Command \"Copy-Item README.github.md README.md; Remove-Item README.github.md\"",
    "package": "npm run prevsce && vsce package --no-dependencies && npm run postvsce",
    "deploy": "npm run package && code --install-extension github-copilot-lens-*.vsix --force"
  },
  "keywords": [
    "copilot",
    "dashboard",
    "monitor",
    "session"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/ghcp-lens"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "sharp": "^0.34.5",
    "vitest": "^4.1.2"
  }
}
